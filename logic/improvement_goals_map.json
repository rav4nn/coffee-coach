    "conflicts": [
        {
            "goals": [
                "more_sweetness",
                "less_bitterness"
            ],
            "why_they_conflict": "Sweetness requires higher extraction, but fixing bitterness requires lower extraction.",
            "resolution": "Address less_bitterness first because overwhelming bitter compounds will mask any natural sweetness present.",
            "combined_approach": null
        },
        {
            "goals": [
                "more_body",
                "more_clarity"
            ],
            "why_they_conflict": "Body relies on high dissolved solids and oils, while clarity is achieved by removing them.",
            "resolution": "Address more_clarity first, as excessive fines and muddiness can ruin the flavour profile, though this is ultimately a fundamental preference tradeoff.",
            "combined_approach": null
        },
        {
            "goals": [
                "stronger_cup",
                "less_bitterness"
            ],
            "why_they_conflict": "Increasing the coffee dose for a stronger cup also increases the total amount of bitter compounds in the final brew.",
            "resolution": "Address less_bitterness first to fix the extraction balance before scaling up the intensity.",
            "combined_approach": null
        },
        {
            "goals": [
                "more_complexity",
                "smoother_mouthfeel"
            ],
            "why_they_conflict": "Complexity often involves extracting nuanced, bright, and sharp acidic edges, which works against a rounded, smooth texture.",
            "resolution": "Address smoother_mouthfeel first by lowering extraction slightly to remove harshness, then evaluate if complexity is sufficient.",
            "combined_approach": "Decrease water temperature slightly. This removes harsh edges but retains more acidity and complexity than changing the grind size would."
        }
    ],
    "magnitude_resolution": {
        "description": "How rating tier + goal modifier combine to form final recommendation magnitude. Ratings provide baseline, modifiers shift up or down one tier (capped at aggressive and nudge).",
        "matrix": {
            "aggressive": {
                "shift_up": "aggressive",
                "neutral": "aggressive",
                "shift_down": "moderate"
            },
            "moderate": {
                "shift_up": "aggressive",
                "neutral": "moderate",
                "shift_down": "nudge"
            },
            "nudge": {
                "shift_up": "moderate",
                "neutral": "nudge",
                "shift_down": "nudge"
            },
            "none": {
                "shift_up": "none",
                "neutral": "none",
                "shift_down": "none"
            }
        }
    }
