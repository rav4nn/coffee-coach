{
    "version": "1.0",
    "description": "Magnitude calibration rules for adjusting coffee brewing parameters based on user ratings and declared improvement goals.",
    "rating_tiers": {
        "1-4": "aggressive",
        "5-6": "moderate",
        "7-8": "nudge",
        "9-10": "none"
