            "id": "more_sweetness",
            "display_name": "More Sweetness",
            "description": "Increase extraction to hit the 18-22% sweet spot where natural coffee sugars are most prominent.",
            "magnitude_modifier": "neutral",
            "primary_variable": "grind_size",
            "direction": "finer",
            "secondary_variable": "water_temperature",
            "secondary_direction": "hotter",
            "method_exceptions": {
                "cold_brew": {
                    "secondary_variable": "brew_time",
                    "secondary_direction": "longer"
                },
                "french_press": {
                    "secondary_variable": "brew_time",
                    "secondary_direction": "longer"
                },
                "aeropress": {
                    "secondary_variable": "brew_time",
                    "secondary_direction": "longer"
                },
                "south_indian_filter": {
