# ── Hetzner / Backend ──────────────────────────────────────────────────────
POSTGRES_USER=coffee_coach
POSTGRES_PASSWORD=psgtgrs
POSTGRES_DB=coffee_coach

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://coffee-coach.vercel.app

# ── Vercel / Frontend ──────────────────────────────────────────────────────
# Server-side only — Vercel proxies /backend/* to this URL (avoids mixed content)
BACKEND_URL=http://89.167.56.80:8080

# NEXT_PUBLIC_API_BASE_URL must be set to /backend so the browser
# calls your Vercel domain (HTTPS) instead of Hetzner directly (HTTP)
NEXT_PUBLIC_API_BASE_URL=/backend

# ── Test Agents ─────────────────────────────────────────────────────────────
# Secret for minting test user tokens (POST /api/test-auth/token)
# Keep separate from AUTH_SECRET so a leak doesn't compromise real user sessions
TEST_SECRET=change-me-to-a-random-string
