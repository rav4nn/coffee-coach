# ── Backend ────────────────────────────────────────────────────────────────
POSTGRES_USER=coffee_coach
POSTGRES_PASSWORD=change-me
POSTGRES_DB=coffee_coach

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend-domain.example.com

# Admin user ID (Google OAuth sub) for /api/admin endpoints
ADMIN_USER_ID=your-google-oauth-sub

# ── Frontend ──────────────────────────────────────────────────────────────
# Server-side only — proxies /backend/* to this URL (avoids mixed content)
BACKEND_URL=http://your-server-ip:8080

# NEXT_PUBLIC_API_BASE_URL must be set to /backend so the browser
# calls your domain (HTTPS) instead of the server directly (HTTP)
NEXT_PUBLIC_API_BASE_URL=/backend

# ── Auth ──────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_ADMIN_USER_ID=your-google-oauth-sub
